# secureChat — .env example
#
# Copy this file to .env and fill in the values you want to change.
# All values are optional — secureChat works out-of-the-box without any .env file.
# Existing environment variables (e.g. from your shell) are NOT overwritten.
#
# Usage:
#   cp .env.example .env
#   # Edit .env as needed, then:
#   python run.py

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# TCP port the server listens on (default: 5000)
# PORT=5000

# Bind interface (default: 127.0.0.1 when Tor is active, 0.0.0.0 otherwise)
# HOST=127.0.0.1

# Path to the SQLite database file (default: securechat.db next to run.py)
# DB_PATH=/path/to/securechat.db

# ---------------------------------------------------------------------------
# Custom / persistent URL paths
# ---------------------------------------------------------------------------
#
# By default secureChat generates a new random secret path for the admin panel
# and the clearnet access URL on every fresh install.  The first time the
# server runs it writes the auto-generated values to this .env file so that
# the same paths are reused on subsequent restarts.
#
# You can also set a completely custom value here before the first run — for
# example a memorable name that you want to share with specific people:
#
#   CLEARNET_PATH=MySecureChatServiceName
#   ADMIN_PATH=MyPrivateAdminArea
#
# Rules:
#   • Use only URL-safe characters (letters, digits, - _ ~).
#   • CLEARNET_PATH should be hard to guess (at least 20 random-looking chars).
#   • ADMIN_PATH   should be very hard to guess (at least 50 random-looking chars).
#   • ADMIN_PASSCODE is the password that protects the admin panel.
#   • ADMIN_WEBHOOK_TOKEN is the secret that authorises the incoming webhook.
#   • MESH_TOKEN is the invite secret for the server-to-server mesh network.
#
# All five are auto-generated and saved to this file on the first run if you
# leave them unset.  To rotate any secret, simply delete its line here and
# restart the server.

# Clearnet access URL path — share only over a secure channel (default: auto-generated)
# CLEARNET_PATH=<your-custom-or-auto-generated-path>

# Admin panel URL path (default: auto-generated, 200 chars)
# ADMIN_PATH=<your-custom-or-auto-generated-path>

# Admin panel passcode (default: auto-generated, 100 chars)
# ADMIN_PASSCODE=<your-custom-or-auto-generated-passcode>

# Admin incoming webhook token (default: auto-generated)
# ADMIN_WEBHOOK_TOKEN=<your-custom-or-auto-generated-token>

# Mesh network invite secret (default: auto-generated)
# MESH_TOKEN=<your-custom-or-auto-generated-token>

# ---------------------------------------------------------------------------
# Tor
# ---------------------------------------------------------------------------

# Set to 1 to skip Tor even if it is installed (default: not set / Tor enabled)
# NO_TOR=1

# Absolute path to the tor binary (default: auto-detected)
# TOR_PATH=/usr/bin/tor

# Your known .onion address — set this if you already have a hostname so that
# invite links and /api/server-info return the correct onion URL.
# Leave unset and Tor will auto-generate one on first run.
# ONION_ADDRESS=yourhostname.onion

# ---------------------------------------------------------------------------
# Mesh / Federation
# ---------------------------------------------------------------------------

# Automatically join a remote peer at startup.
# Set both MESH_JOIN and MESH_TOKEN together.
#
# MESH_JOIN is the full /mesh/peer/connect URL of the remote server.
# MESH_TOKEN is the MESH_TOKEN printed by the remote server at startup.
#
# Example:
# MESH_JOIN=http://zn6pflnphvgs5usexqam4q6l55j2nfa6eal2rrofdcq3sbgs57brdeid.onion/mesh/peer/connect
# MESH_TOKEN=<32-char-token-printed-by-remote-server>

# ---------------------------------------------------------------------------
# Mail / SMTP
# ---------------------------------------------------------------------------

# Your real mail domain (e.g. yourdomain.com).
# Required to accept inbound email directly on port 25.
# Without this, secureChat uses the automatic mail.tm disposable address.
# MAIL_DOMAIN=yourdomain.com

# SMTP listen port (default: 25; use 2525 if not running as root)
# SMTP_PORT=25

# ---------------------------------------------------------------------------
# Relay webhook (IP-private inbound email)
# ---------------------------------------------------------------------------

# Secret shared with your relay service (Mailgun, SendGrid, Cloudflare, …).
# Auto-generated if not set; printed to the console at startup.
# RELAY_SECRET=your-secret-here

# ---------------------------------------------------------------------------
# Auto-update (git pull)
# ---------------------------------------------------------------------------

# Set to 1 to automatically run "git pull --ff-only" before starting the server.
# Disabled by default. Only works when the server is launched from a git clone.
# AUTO_UPDATE=1

# ---------------------------------------------------------------------------
# Slow mode
# ---------------------------------------------------------------------------

# Set to 1 to start the server with slow mode already active (default: off).
# When active, every non-admin request is delayed by SLOW_MODE_DELAY seconds.
# Admins can toggle slow mode at runtime via POST /{admin_path}/api/slow-mode.
# SLOW_MODE=0

# Delay in seconds applied to each request while slow mode is active (default: 2.0).
# SLOW_MODE_DELAY=2.0

# ---------------------------------------------------------------------------
# DDoS protection
# ---------------------------------------------------------------------------

# Set to 0 to disable the built-in DDoS guard entirely (default: enabled).
# DDOS_ENABLED=1

# Max requests per IP inside the sliding window before the IP is banned (default: 200).
# DDOS_REQ_LIMIT=200

# Sliding window length in seconds (default: 10).
# DDOS_WINDOW_SEC=10

# How long a banned IP stays blocked in seconds (default: 300 = 5 min).
# DDOS_BAN_SEC=300

# Number of unique IPs banned within one window that triggers automatic lockdown (default: 50).
# DDOS_AUTO_LOCKDOWN_THRESHOLD=50

# ---------------------------------------------------------------------------
# Spam protection
# ---------------------------------------------------------------------------

# Set to 0 to disable the built-in chat/mail spam filter (default: enabled).
# SPAM_ENABLED=1

# Max chat messages per sender inside the sliding window (default: 20).
# SPAM_MSG_LIMIT=20

# Chat spam sliding window in seconds (default: 10).
# SPAM_MSG_WINDOW=10

# Max inbound emails per sender inside the sliding window (default: 5).
# SPAM_MAIL_LIMIT=5

# Mail spam sliding window in seconds (default: 60).
# SPAM_MAIL_WINDOW=60

# ---------------------------------------------------------------------------
# Chat history
# ---------------------------------------------------------------------------

# Max messages stored and replayed per room. Oldest are pruned automatically (default: 100).
# HISTORY_LIMIT=100

# ---------------------------------------------------------------------------
# mail.tm
# ---------------------------------------------------------------------------

# Set to 0 to disable the automatic mail.tm disposable-address integration (default: enabled).
# Only applies when MAIL_DOMAIN and RELAY_SECRET are both unset.
# MAILTM_ENABLED=1
