# See info-files/env-vars.md for documentation on every variable.

# ─── Server ──────────────────────────────────────────────────────────────────
# PORT=5000
# HOST=127.0.0.1
# DB_PATH=

# ─── Custom / persistent URL paths ──────────────────────────────────────────
# CLEARNET_PATH=
# ADMIN_PATH=
# ADMIN_PASSCODE=
# ADMIN_WEBHOOK_TOKEN=
# MESH_TOKEN=

# ─── Tor ─────────────────────────────────────────────────────────────────────
# NO_TOR=1
# TOR_PATH=
# ONION_ADDRESS=

# ─── Mesh / Federation ───────────────────────────────────────────────────────
# MESH_JOIN=
# MESH_TOKEN=

# ─── Mail / SMTP ─────────────────────────────────────────────────────────────
# MAIL_DOMAIN=
# SMTP_PORT=25
# RELAY_SECRET=

# ─── Auto-update ─────────────────────────────────────────────────────────────
# AUTO_UPDATE=1
# When set, run.py pulls the latest code from the main branch on GitHub
# (https://github.com/Kitywiel/secureChat-1.0) before starting.
# If the directory is not yet a git repository it is initialised and the
# code is fetched automatically — no manual 'git clone' needed.

# ─── Slow mode ───────────────────────────────────────────────────────────────
# SLOW_MODE=0
# SLOW_MODE_DELAY=2.0

# ─── DDoS protection ─────────────────────────────────────────────────────────
# DDOS_ENABLED=1
# DDOS_REQ_LIMIT=200
# DDOS_WINDOW_SEC=10
# DDOS_BAN_SEC=300
# DDOS_AUTO_LOCKDOWN_THRESHOLD=50

# ─── Spam protection ─────────────────────────────────────────────────────────
# SPAM_ENABLED=1
# SPAM_MSG_LIMIT=20
# SPAM_MSG_WINDOW=10
# SPAM_MAIL_LIMIT=5
# SPAM_MAIL_WINDOW=60

# ─── Chat history ─────────────────────────────────────────────────────────────
# HISTORY_LIMIT=100

# ─── mail.tm ─────────────────────────────────────────────────────────────────
# MAILTM_ENABLED=1

# ─── Local Mesh (multi-instance on the same machine) ─────────────────────────
# Run  python local_mesh.py  once, then start each server instance with both
# variables set to the same values.  Chat messages and file downloads are
# then shared across all local instances over the loopback interface.
#
# Usage:
#   python local_mesh.py                         (start the hub first)
#   LOCAL_MESH_PORT=9000 FILE_STORAGE=storage PORT=5000 python run.py
#   LOCAL_MESH_PORT=9000 FILE_STORAGE=storage PORT=5001 python run.py
#
# LOCAL_MESH_PORT=9000
# FILE_STORAGE=storage
# SERVER_NAME=my-node-1
# MAIN_SERVER=1
